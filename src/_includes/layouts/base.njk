<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
    <link rel="stylesheet" href="/style.css">
  </head>
  <body class="text-zinc-950 antialiased">
    <div class="mx-auto flex min-h-screen max-w-4xl flex-col px-6 py-8 sm:px-8">
      <header class="flex flex-col gap-6 border-b border-black/15 pb-6 sm:flex-row sm:items-end sm:justify-between">
        <p class="text-lg font-medium tracking-tight">
          <a class="transition hover:text-black/65" href="/">{{ site.title }}</a>
        </p>
        <nav aria-label="Основное меню">
          <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-black/70">
          {% for item in site.navigation %}
            <li>
              <a
                class="nav-link {% if page.url == item.url %}text-black font-semibold{% else %}transition hover:text-black{% endif %}"
                data-label="{{ item.title }}"
                href="{{ item.url }}"
              >
                {{ item.title }}
              </a>
            </li>
          {% endfor %}
          </ul>
        </nav>
      </header>

      <main class="flex-1 py-10 sm:py-14">
        {% block content %}{{ content | safe }}{% endblock %}
      </main>

      <footer class="border-t border-black/15 pt-6">
        <p class="text-sm text-black/60">Соцсети</p>
        <ul class="mt-3 flex flex-wrap gap-4 text-black/75">
        {% for item in site.socialLinks %}
          <li>
            <a
              class="flex h-10 w-10 items-center justify-center rounded-full border border-black/15 transition hover:border-black/35 hover:text-black"
              href="{{ item.url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ item.title }}"
              title="{{ item.title }}"
            >
              {% if item.icon == "telegram" %}
                <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M21.75 4.2c.16-.75-.17-1.04-.86-.79L3.11 10.3c-.72.29-.71.69-.13.87l4.57 1.43 1.77 5.54c.22.67.11.94.82.94.55 0 .79-.25 1.1-.55.19-.18 1.33-1.29 2.59-2.51l5.38 3.97c.99.55 1.7.27 1.95-.91L21.75 4.2Zm-3 2.11-7.34 6.61-.29 3.1-.98-3.08-5.3-1.66 13.91-5.37Z"/>
                </svg>
              {% elif item.icon == "instagram" %}
                <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M7.25 2h9.5A5.25 5.25 0 0 1 22 7.25v9.5A5.25 5.25 0 0 1 16.75 22h-9.5A5.25 5.25 0 0 1 2 16.75v-9.5A5.25 5.25 0 0 1 7.25 2Zm0 1.5A3.75 3.75 0 0 0 3.5 7.25v9.5a3.75 3.75 0 0 0 3.75 3.75h9.5a3.75 3.75 0 0 0 3.75-3.75v-9.5a3.75 3.75 0 0 0-3.75-3.75h-9.5Zm10 1.75a1 1 0 1 1 0 2 1 1 0 0 1 0-2ZM12 6.5A5.5 5.5 0 1 1 6.5 12 5.51 5.51 0 0 1 12 6.5Zm0 1.5A4 4 0 1 0 16 12a4 4 0 0 0-4-4Z"/>
                </svg>
              {% elif item.icon == "youtube" %}
                <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23 12.01s0-3.04-.39-4.5a3.02 3.02 0 0 0-2.12-2.12C19.03 5 12 5 12 5s-7.03 0-8.49.39A3.02 3.02 0 0 0 1.39 7.5C1 8.97 1 12.01 1 12.01s0 3.04.39 4.5a3.02 3.02 0 0 0 2.12 2.12C4.97 19 12 19 12 19s7.03 0 8.49-.39a3.02 3.02 0 0 0 2.12-2.12c.39-1.46.39-4.5.39-4.5ZM9.75 15.5v-7l6 3.5-6 3.5Z"/>
                </svg>
              {% else %}
                <span class="text-sm">{{ item.label }}</span>
              {% endif %}
            </a>
          </li>
        {% endfor %}
        </ul>
      </footer>
    </div>
  </body>
</html>
