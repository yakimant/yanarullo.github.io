---
layout: layouts/base.njk
---
{% block content %}
  <article class="{% if page.url == '/' %}home-page{% else %}max-w-2xl{% endif %}">
    <h1 class="page-title">{{ title }}</h1>
    <div class="prose prose-zinc mt-6 max-w-none {% if page.url == '/' %}home-page__body{% endif %}">
      {{ content | safe }}
    </div>
  </article>
{% endblock %}
